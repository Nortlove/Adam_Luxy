# FastAPI backend URL (exposed to client — safe to be public)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Server-side Bearer token for FastAPI (never exposed to client)
INFORMATIV_API_TOKEN=replace-with-token

# Display identity for the single pilot user
INFORMATIV_USER_EMAIL=chris@informativgroup.com
INFORMATIV_USER_NAME=Chris Nocera
