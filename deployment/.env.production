# =============================================================================
# INFORMATIV Production Environment Variables
# Copy to .env on the production server and fill in values
# =============================================================================

# ── APPLICATION ──
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
APP_NAME=INFORMATIV
APP_VERSION=1.0.0

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000
ADAM_API_KEYS=<<REPLACE_WITH_YOUR_API_KEY>>
CORS_ORIGINS=["https://luxyride.com","https://www.luxyride.com","http://localhost:3000"]

# ── NEO4J ──
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<<REPLACE_WITH_NEO4J_PASSWORD>>
NEO4J_DATABASE=neo4j
NEO4J_POOL_SIZE=50

# ── REDIS ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# ── CLAUDE API ──
ANTHROPIC_API_KEY=<<REPLACE_WITH_ANTHROPIC_KEY>>
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_TIMEOUT=60

# ── STACKADAPT ──
STACKADAPT_WEBHOOK_SECRET=<<REPLACE_WITH_WEBHOOK_SECRET>>
STACKADAPT_ADVERTISER_ID=<<REPLACE>>
STACKADAPT_API_KEY=<<REPLACE>>
STACKADAPT_PIXEL_ID=<<REPLACE>>

# ── LATENCY BUDGET ──
LATENCY_TOTAL_MS=120
LATENCY_RESERVE_MS=10
LATENCY_PREFETCH_MS=40
LATENCY_CASCADE_MS=60
LATENCY_DAG_MS=80

# ── RETARGETING THRESHOLDS ──
THRESHOLD_RETARGET_MAX_TOUCHES=7
THRESHOLD_RETARGET_REACTANCE=0.85
THRESHOLD_RETARGET_CTR_FLOOR=0.0003
