# ADAM Platform Environment Variables

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Anthropic Configuration
ANTHROPIC_API_KEY=your_api_key_here

# StackAdapt Webhook (required for live outcome processing)
# The webhook endpoint refuses all requests if STACKADAPT_WEBHOOK_SECRET
# is empty. Generate a 32-byte random hex string for this value and
# share it with StackAdapt when configuring their conversion webhook.
# An unauthenticated webhook is a security and learning-integrity hole,
# not a dev-convenience feature — see ADAM_THEORETICAL_FOUNDATION rule #11.
STACKADAPT_WEBHOOK_SECRET=
# Deduplication window. Must cover the longest StackAdapt retry interval.
# Default 48h (172800s) is conservative. Tune down if the real retry
# policy is shorter.
STACKADAPT_WEBHOOK_DEDUP_TTL_SECONDS=172800

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
